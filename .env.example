# Business Leads AI Automation v2.0 Configuration
# Copy this file to .env and update the values

# REQUIRED: OpenAI API Configuration
#OPENAI_BASE_URL=https://api.groq.com/openai/v1
#OPENAI_API_KEY=your_groq_key
#OPENAI_MODEL=llama3-70b-8192
#WEB_PORT=3000

# OPTIONAL: Custom OpenAI Base URL (for Azure, OpenRouter, local LLM proxies, etc.)
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1

# INDUSTRY & CAMPAIGN SETTINGS (Set by setup wizard, or override here)
#PRIMARY_INDUSTRY=professional
#CAMPAIGN_STYLE=balanced

# OUTPUT LANGUAGE (indonesian / english)
#OUTPUT_LANGUAGE=indonesian

# SCRAPING CONFIGURATION
#DELAY_BETWEEN_SCRAPES=2000
#MAX_RETRIES=3
#DEFAULT_RESULT_LIMIT=20

# OUTPUT SETTINGS
#OUTPUT_FORMAT=csv
#OUTPUT_DIRECTORY=output

# LEAD INTELLIGENCE SETTINGS
#MIN_LEAD_SCORE=60
#ENABLE_LEAD_SCORING=true
#PRIORITIZE_HIGH_RATING=true

# MARKETING AI SETTINGS
#ENABLE_INDUSTRY_TEMPLATES=true
#GENERATE_MULTI_TOUCH=false
#MAX_CONTENT_GENERATION=50

# ADVANCED SETTINGS (Optional)
#ENABLE_DEBUG_LOGGING=false
#SAVE_PROGRESS_LOGS=true
#AUTO_CLEANUP_OLD_CAMPAIGNS=false

# NOTE: Business profile (name, phone, email, service description, etc.)
# is configured in business-profile.json — run: npm run setup

# FUTURE FEATURES (Coming Soon)
# WEBHOOK_URL=
# CRM_INTEGRATION=
# EMAIL_SERVICE_API=
# ANALYTICS_TRACKING=


############################################################################################################################################################################
# Vrixo Lead Generation System — Configuration

# AI PROVIDER (Groq)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=your_groq_key_here
OPENAI_MODEL=llama3-70b-8192

# SERVER
WEB_PORT=3000

# CAMPAIGN DEFAULTS
PRIMARY_INDUSTRY=dentist
CAMPAIGN_STYLE=balanced
OUTPUT_LANGUAGE=english

# SCRAPING
DELAY_BETWEEN_SCRAPES=2000
MAX_RETRIES=3
DEFAULT_RESULT_LIMIT=20

# OUTPUT
OUTPUT_FORMAT=csv
OUTPUT_DIRECTORY=output

# LEAD SCORING
MIN_LEAD_SCORE=60
ENABLE_LEAD_SCORING=true
PRIORITIZE_HIGH_RATING=true

# MARKETING AI
ENABLE_INDUSTRY_TEMPLATES=true
GENERATE_MULTI_TOUCH=false
MAX_CONTENT_GENERATION=50

# DEBUG
ENABLE_DEBUG_LOGGING=false
SAVE_PROGRESS_LOGS=true
AUTO_CLEANUP_OLD_CAMPAIGNS=false
